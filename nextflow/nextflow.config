/*
=============================================================================
    NEXTFLOW CONFIGURATION
=============================================================================
*/

manifest {
    name = "AMR Detection Pipeline"
    author = "AMR Platform Team"
    description = "Complete Module 1 genome validation and AMR detection pipeline"
    version = "1.0.0"
    nextflowVersion = ">=23.04.0"
    doi = "https://doi.org/10.5281/zenodo/..."
    url = "https://github.com/yourusername/amr-platform"
}

// =============================================================================
// EXECUTION PROFILES
// =============================================================================

profiles {
    docker {
        process {
            executor = "local"
        }
        
        docker {
            enabled = false
        }
    }
    
    singularity {
        process {
            container = "amr-platform.sif"
            executor = "singularity"
        }
        
        singularity {
            enabled = true
            autoMounts = true
            cacheDir = "./.singularity"
        }
    }
    
    slurm {
        process {
            executor = "slurm"
            queue = "normal"
            time = "4h"
            memory = "8 GB"
            cpus = 4
        }
        
        executor {
            queueSize = 100
            pollInterval = "30 sec"
        }
    }
    
    local {
        process {
            executor = "local"
        }
    }
    
    test {
        params {
            samples = "${projectDir}/test_data/samples.csv"
            output = "test_results"
            validation_cpus = 2
            alignment_cpus = 2
            amr_cpus = 2
        }
        
        process {
            executor = "local"
            cpus = 2
            memory = "4 GB"
        }
    }
}

// =============================================================================
// GLOBAL SETTINGS
// =============================================================================

process {
    // Default container for all processes
    container = null  // Set via profile
    
    // Process labels for resource allocation
    withLabel: validation {
        cpus = { params.validation_cpus }
        memory = { params.validation_memory }
        time = "2h"
    }
    
    withLabel: alignment {
        cpus = { params.alignment_cpus }
        memory = { params.alignment_memory }
        time = "4h"
    }
    
    withLabel: amr_detection {
        cpus = { params.amr_cpus }
        memory = { params.amr_memory }
        time = "6h"
    }
    
    withLabel: aggregation {
        cpus = 2
        memory = "4 GB"
        time = "1h"
    }
    
    withLabel: reporting {
        cpus = 2
        memory = "4 GB"
        time = "1h"
    }
    
    // Retry logic
    maxRetries = 2
    errorStrategy = "retry"
}

// =============================================================================
// EXECUTOR SETTINGS
// =============================================================================

executor {
    name = "local"
    queueSize = 4
    pollInterval = "1 min"
}

// =============================================================================
// TRACE AND REPORTS
// =============================================================================

trace {
    enabled = true
    file = "${params.output}/.nextflow/trace.txt"
    fields = "task_id,name,status,exit,realtime,cpus,%cpu,memory,%mem"
}

timeline {
    enabled = true
    file = "${params.output}/.nextflow/timeline.html"
}

report {
    enabled = true
    file = "${params.output}/.nextflow/report.html"
}

// =============================================================================
// CLEANUP
// =============================================================================

cleanup = false  // Keep work directory for debugging

// =============================================================================
// CONDA ENVIRONMENT (Alternative to containers)
// =============================================================================

conda {
    enabled = false
    cacheDir = "./.conda"
}

// =============================================================================
// WORKING DIRECTORY
// =============================================================================

workDir = "${projectDir}/.nextflow/work"

// =============================================================================
// LOGGING
// =============================================================================

trace.overwrite = true
